package day1;
  
public class OperatorsDemo {
	
    public static void main(String[] args) {
         
    	int num = 10;
    	
    	if (num > 0) {
    		System.out.println ("Positive Number");
    	}
    	else if (num < 0) {
    		System.out.println ("Negative Number");
    	}
    	else {
    		System.out.println ("The Number is zero");
    	}
    } 
}
